          "rules": [
            {
              "id": "OJS-SC-SQLINJECTION-TAINT",
              "name": "SQL Injection via tainted input",
              "shortDescription": {
                "text": "SQL Injection via tainted input"
              },
              "fullDescription": {
                "text": "Data from user input ($_GET['id']) flows into a dangerous function (retrieve) without adequate sanitization."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "",
              "properties": {
                "tags": [
                  "CWE-89",
                  "A03:2021"
                ]
              }
            },
            {
              "id": "OJS-SC-RCE-TAINT",
              "name": "Remote Code Execution via tainted input",
              "shortDescription": {
                "text": "Remote Code Execution via tainted input"
              },
              "fullDescription": {
                "text": "Data from user input ($_REQUEST['filename']) flows into a dangerous function (exec) without adequate sanitization."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "",
              "properties": {
                "tags": [
                  "CWE-78",
                  "A03:2021"
                ]
              }
            },
            {
