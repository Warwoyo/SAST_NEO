        },
        {
          "ruleId": "OJS-SC-SQLI-003",
          "level": "error",
          "message": {
            "text": "The OJS DAO retrieve() method is called with interpolated variables, which may allow SQL injection if the variables are not properly sanitized.\n"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "/home/wiyu/Documents/01. Skripsi/code/SAST_NEO/tests/fixtures/php_vulnerable/vulnerable.php"
                },
                "region": {
                  "startLine": 4,
                  "endLine": 4,
                  "snippet": {
                    "text": "       2 | // VULNERABLE: SQL Injection via $_GET in raw query\n       3 | $id = $_GET['id'];\n>>>    4 | $result = $this->retrieve(\"SELECT * FROM submissions WHERE id = \" . $id);\n       5 | \n       6 | // VULNERABLE: XSS via direct echo of user input"
                  }
                }
              }
            }
          ],
          "fixes": [
            {
              "description": {
                "text": "Use the array-based parameter binding in OJS DAO: $this->retrieve('SELECT * FROM t WHERE id = ?', array((int) $id));\n"
              }
            }
          ]
        },
