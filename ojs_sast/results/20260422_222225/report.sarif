              "properties": {
                "tags": [
                  "CWE-89",
                  "A03:2021"
                ]
              }
            },
            {
              "id": "OJS-SC-SQLI-003",
              "name": "SQL Injection in OJS DAO retrieve method",
              "shortDescription": {
                "text": "SQL Injection in OJS DAO retrieve method"
              },
              "fullDescription": {
                "text": "The OJS DAO retrieve() method is called with interpolated variables, which may allow SQL injection if the variables are not properly sanitized.\n"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "",
              "properties": {
                "tags": [
                  "CWE-89",
                  "A03:2021"
                ]
              }
            },
            {
