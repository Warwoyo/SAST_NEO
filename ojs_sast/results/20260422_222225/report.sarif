                  "A03:2021"
                ]
              }
            },
            {
              "id": "OJS-SC-RCE-001",
              "name": "Remote Code Execution via eval with user input",
              "shortDescription": {
                "text": "Remote Code Execution via eval with user input"
              },
              "fullDescription": {
                "text": "The eval() function executes arbitrary PHP code. If it receives user-controlled input, an attacker can execute arbitrary commands.\n"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/94.html",
              "properties": {
                "tags": [
                  "CWE-94",
                  "A03:2021"
                ]
              }
            },
            {
              "id": "OJS-SC-RCE-002",
              "name": "Command Injection via shell execution functions",
              "shortDescription": {
                "text": "Command Injection via shell execution functions"
              },
              "fullDescription": {
                "text": "Shell execution functions (exec, system, shell_exec, passthru, popen) receive user-controlled input, enabling OS command injection.\n"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "",
              "properties": {
                "tags": [
                  "CWE-78",
                  "A03:2021"
                ]
              }
            },
            {
              "id": "OJS-SC-RCE-003",
              "name": "Code execution via preg_replace with /e modifier",
              "shortDescription": {
                "text": "Code execution via preg_replace with /e modifier"
              },
              "fullDescription": {
                "text": "The preg_replace() function with the /e modifier evaluates the replacement string as PHP code. This is deprecated and dangerous.\n"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "",
              "properties": {
                "tags": [
                  "CWE-94",
                  "A03:2021"
                ]
              }
            },
            {
              "id": "OJS-SC-SQLI-002",
              "name": "SQL Injection via string concatenation in query",
              "shortDescription": {
                "text": "SQL Injection via string concatenation in query"
              },
              "fullDescription": {
                "text": "A SQL query is built using string concatenation with variables that may contain user input, creating a SQL injection vulnerability.\n"
