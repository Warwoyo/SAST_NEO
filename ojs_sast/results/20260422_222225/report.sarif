              "shortDescription": {
                "text": "Reflected XSS via direct output of user input"
              },
              "fullDescription": {
                "text": "User input from superglobals is directly echoed to the browser without HTML encoding, allowing reflected XSS attacks.\n"
              },
              "defaultConfiguration": {
                "level": "error"
